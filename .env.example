VITE_API_URL=https://stayflow-production-bc16.up.railway.app/api

# Backend vars. Needed when running the merged production server (node scripts/start.mjs)
# from repo root, and by the Prisma CLI + standalone backend dev server. This is the
# ONLY .env in the repo — there is deliberately no server/.env. On Railway these are
# set directly as service env vars, not via this file. See docs/Security.md.
DATABASE_URL=postgresql://user:password@host:5432/db
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Only needed by the standalone backend dev server (server/: npm run dev, port 4000)
# talking to a separately-run frontend dev server (vite dev --port 3000).
PORT=4000
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.example
